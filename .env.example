DB_USER=oneway
DB_PASSWORD=onewaypass
DB_NAME=onewaydb
DB_HOST=localhost
DB_PORT=5432

# Notes:
# - Copy this file to .env in the same folder before running `docker-compose up`.
# - `DB_HOST` is what your backend should use to connect. When running the backend on
#   your host machine and using docker-compose above, keep DB_HOST=localhost and
#   DB_PORT=5432 (or adapt if you change ports).
DB_USER=postgres
DB_PASSWORD=secret
DB_HOST=localhost
DB_NAME=oneway
PORT=3000
JWT_SECRET=change_this_secret
GOOGLE_MAPS_API_KEY=your_google_maps_key
